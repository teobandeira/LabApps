generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ImageGenerationAction {
  generate
  edit
}

enum ChatMessageRole {
  user
  assistant
}

enum CreditLedgerKind {
  grant
  debit
  refund
  adjust
}

enum CreditReferenceType {
  image_generation
  video_generation
  admin
  other
}

model GeneratedImage {
  id              String                @id @default(cuid())
  deviceId        String?               @db.VarChar(120)
  prompt          String                @db.Text
  revisedPrompt   String?               @db.Text
  model           String                @db.VarChar(80)
  size            String                @db.VarChar(24)
  action          ImageGenerationAction
  sourceImageName String?               @db.VarChar(255)
  openaiImageUrl  String?               @db.VarChar(2048)
  blobUrl         String                @db.VarChar(2048)
  blobPath        String                @db.VarChar(255)
  mimeType        String                @db.VarChar(120)
  bytes           Int
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([deviceId, createdAt])
  @@index([createdAt])
}

model GeneratedVideo {
  id              String   @id @default(cuid())
  deviceId        String?  @db.VarChar(120)
  sourceImageId   String?  @db.VarChar(120)
  operationName   String   @unique @db.VarChar(255)
  model           String   @db.VarChar(80)
  aspectRatio     String   @db.VarChar(8)
  durationSeconds Int
  resolution      String   @db.VarChar(16)
  blobUrl         String   @db.VarChar(2048)
  blobPath        String   @db.VarChar(255)
  mimeType        String   @db.VarChar(120)
  bytes           Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([deviceId, createdAt])
  @@index([sourceImageId, createdAt])
  @@index([createdAt])
}

model CreditWallet {
  id             String         @id @default(cuid())
  deviceId       String         @unique @db.VarChar(120)
  initialCredits Int            @default(100)
  balance        Int            @default(100)
  totalSpent     Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  ledgerEntries  CreditLedger[]
}

model CreditLedger {
  id            String              @id @default(cuid())
  walletId      String
  kind          CreditLedgerKind
  amount        Int
  balanceBefore Int
  balanceAfter  Int
  reason        String              @db.VarChar(255)
  referenceType CreditReferenceType @default(other)
  referenceId   String?             @db.VarChar(191)
  requestId     String?             @unique @db.VarChar(191)
  createdAt     DateTime            @default(now())
  wallet        CreditWallet        @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([referenceType, referenceId])
}

model ChatSession {
  id        String               @id @default(cuid())
  deviceId  String               @db.VarChar(120)
  title     String               @db.VarChar(120)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  messages  ChatSessionMessage[]

  @@index([deviceId, updatedAt])
}

model ChatSessionMessage {
  id        String          @id @default(cuid())
  sessionId String
  role      ChatMessageRole
  content   String          @db.Text
  imageUrl  String?         @db.VarChar(2048)
  imageId   String?         @db.VarChar(120)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  session   ChatSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}
