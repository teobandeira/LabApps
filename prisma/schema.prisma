generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum ImageGenerationAction {
  generate
  edit
}

enum ChatMessageRole {
  user
  assistant
}

enum CreditLedgerKind {
  grant
  debit
  refund
  adjust
}

enum CreditReferenceType {
  image_generation
  video_generation
  admin
  other
}

model GeneratedImage {
  id              String                @id @default(cuid())
  deviceId        String?               @db.VarChar(120)
  prompt          String                @db.Text
  revisedPrompt   String?               @db.Text
  model           String                @db.VarChar(80)
  size            String                @db.VarChar(24)
  action          ImageGenerationAction
  sourceImageName String?               @db.VarChar(255)
  openaiImageUrl  String?               @db.VarChar(2048)
  blobUrl         String                @db.VarChar(2048)
  blobPath        String                @db.VarChar(255)
  mimeType        String                @db.VarChar(120)
  bytes           Int
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([deviceId, createdAt])
  @@index([createdAt])
}

model GeneratedVideo {
  id              String   @id @default(cuid())
  deviceId        String?  @db.VarChar(120)
  sourceImageId   String?  @db.VarChar(120)
  operationName   String   @unique @db.VarChar(255)
  model           String   @db.VarChar(80)
  aspectRatio     String   @db.VarChar(8)
  durationSeconds Int
  resolution      String   @db.VarChar(16)
  blobUrl         String   @db.VarChar(2048)
  blobPath        String   @db.VarChar(255)
  mimeType        String   @db.VarChar(120)
  bytes           Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([deviceId, createdAt])
  @@index([sourceImageId, createdAt])
  @@index([createdAt])
}

model CreditWallet {
  id             String         @id @default(cuid())
  deviceId       String         @unique @db.VarChar(120)
  initialCredits Int            @default(100)
  balance        Int            @default(100)
  totalSpent     Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  ledgerEntries  CreditLedger[]
}

model CreditLedger {
  id            String              @id @default(cuid())
  walletId      String
  kind          CreditLedgerKind
  amount        Int
  balanceBefore Int
  balanceAfter  Int
  reason        String              @db.VarChar(255)
  referenceType CreditReferenceType @default(other)
  referenceId   String?             @db.VarChar(191)
  requestId     String?             @unique @db.VarChar(191)
  createdAt     DateTime            @default(now())
  wallet        CreditWallet        @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([referenceType, referenceId])
}

model ChatSession {
  id        String               @id @default(cuid())
  deviceId  String               @db.VarChar(120)
  title     String               @db.VarChar(120)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  messages  ChatSessionMessage[]

  @@index([deviceId, updatedAt])
}

model ChatSessionMessage {
  id        String          @id @default(cuid())
  sessionId String
  role      ChatMessageRole
  content   String          @db.Text
  imageUrl  String?         @db.VarChar(2048)
  imageId   String?         @db.VarChar(120)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  session   ChatSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model MediaProject {
  id            String              @id @default(cuid()) @db.VarChar(191)
  name          String              @db.VarChar(191)
  coverImageUrl String?             @map("cover_image_url") @db.VarChar(2048)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  images        MediaProjectImage[]
  videos        MediaProjectVideo[]

  @@index([createdAt], map: "idx_created_at")
  @@map("chatgpt_media_projects")
}

model MediaProjectImage {
  id        String       @id @default(cuid()) @db.VarChar(191)
  projectId String       @map("project_id") @db.VarChar(191)
  imageId   String       @map("image_id") @db.VarChar(191)
  createdAt DateTime     @default(now()) @map("created_at")
  project   MediaProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, imageId], map: "uq_project_image")
  @@index([imageId], map: "idx_image_id")
  @@map("chatgpt_media_project_images")
}

model MediaProjectVideo {
  id        String       @id @default(cuid()) @db.VarChar(191)
  projectId String       @map("project_id") @db.VarChar(191)
  videoId   String       @map("video_id") @db.VarChar(191)
  createdAt DateTime     @default(now()) @map("created_at")
  project   MediaProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, videoId], map: "uq_project_video")
  @@index([videoId], map: "idx_video_id")
  @@map("chatgpt_media_project_videos")
}
